root = true

[*]
end_of_line = lf
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.cs]
dotnet_sort_system_directives_first = true

# Place braces on the same line
csharp_new_line_before_open_brace = false
csharp_new_line_before_else = false
csharp_new_line_before_catch = false
